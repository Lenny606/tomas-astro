---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import selectedWorks from '../data/selected_works.json';
import { Image } from 'astro:assets';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title="NebulaLab | Creative Developer">
  <section class="max-w-7xl mx-auto px-12 pt-16 pb-32 relative overflow-hidden">
    <div class="max-w-4xl relative">
      <h1 
        class="text-7xl md:text-9xl font-serif tracking-tight mb-12 animate-in fade-in slide-in-from-bottom-8 duration-1000"
        set:html={t('hero.title')}
      />
      
      <p class="text-2xl md:text-3xl text-zinc-400 mb-16 max-w-2xl leading-relaxed font-light">
        {t('hero.subtitle')}
      </p>

      <div class="flex flex-wrap items-center gap-8">
        <a href="#work" class="text-sm uppercase tracking-widest font-bold link-hover" aria-label="View recent work">
          {t('hero.view_work')}
        </a>
      </div>
    </div>
  </section>

  <section id="work" class="max-w-7xl mx-auto px-12 py-32 border-t border-alabaster/5">
    <div class="flex justify-between items-end mb-20">
      <h2 class="text-5xl font-serif">{t('work.title')}</h2>
      <a href="#" class="text-xs uppercase tracking-[0.2em] font-bold text-zinc-500 hover:text-alabaster transition-colors">{t('work.view_all')}</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {selectedWorks.map((work) => (
        <a href={work.url} target="_blank" rel="noopener noreferrer" class="group relative cursor-pointer overflow-hidden plastic aspect-[4/5] bg-zinc-900 border border-alabaster/5 block">
          <!-- Background Image Placeholder -->
          <div class="absolute inset-0 bg-linear-to-br from-zinc-800 to-zinc-900 group-hover:scale-105 transition-transform duration-700 ease-out">
            {work.image && <Image src={work.image} alt={work.title} width={800} height={1000} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-700" />}
          </div>
          
          <!-- Overlay -->
          <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-10">
            <div class="translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
              <p class="text-xs uppercase tracking-[0.2em] text-zinc-400 mb-3">
                {work.category === 'Web Development' ? t('category.web') : work.category}
              </p>
              <h3 class="text-3xl font-serif leading-tight">{work.title}</h3>
              <div class="mt-6 h-[1px] w-0 group-hover:w-full bg-alabaster transition-[width] duration-700 delay-100"></div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-12 py-32 reveal-section">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-20">
      <div class="lg:col-span-5">
        <h2 class="text-6xl md:text-8xl font-serif mb-12 reveal-item leading-tight">
          {t('process.title')}
        </h2>
        <p class="text-2xl text-zinc-400 reveal-item max-w-md">
          {t('process.subtitle')}
        </p>
      </div>

      <div class="lg:col-span-7 space-y-32">
        <div class="reveal-item group">
          <div class="flex items-center gap-6 mb-8">
            <span class="w-12 h-12 rounded-full bg-accent-pink text-black flex items-center justify-center font-bold font-sans">1</span>
            <div class="h-[1px] flex-grow bg-alabaster/10 group-hover:bg-accent-pink/50 transition-colors duration-500"></div>
          </div>
          <h3 class="text-4xl font-serif mb-6">{t('process.step1.title')}</h3>
          <p class="text-xl text-zinc-500 leading-relaxed max-w-xl">{t('process.step1.text')}</p>
        </div>

        <div class="reveal-item group">
          <div class="flex items-center gap-6 mb-8">
            <span class="w-12 h-12 rounded-full bg-accent-green text-black flex items-center justify-center font-bold font-sans">2</span>
            <div class="h-[1px] flex-grow bg-alabaster/10 group-hover:bg-accent-green/50 transition-colors duration-500"></div>
          </div>
          <h3 class="text-4xl font-serif mb-6">{t('process.step2.title')}</h3>
          <p class="text-xl text-zinc-500 leading-relaxed max-w-xl">{t('process.step2.text')}</p>
        </div>

        <div class="reveal-item group">
          <div class="flex items-center gap-6 mb-8">
            <span class="w-12 h-12 rounded-full bg-accent-pink text-black flex items-center justify-center font-bold font-sans">3</span>
            <div class="h-[1px] flex-grow bg-alabaster/10 group-hover:bg-accent-pink/50 transition-colors duration-500"></div>
          </div>
          <h3 class="text-4xl font-serif mb-6">{t('process.step3.title')}</h3>
          <p class="text-xl text-zinc-500 leading-relaxed max-w-xl">{t('process.step3.text')}</p>
        </div>

        <div class="reveal-item group">
          <div class="flex items-center gap-6 mb-8">
            <span class="w-12 h-12 rounded-full bg-accent-green text-black flex items-center justify-center font-bold font-sans">4</span>
            <div class="h-[1px] flex-grow bg-alabaster/10 group-hover:bg-accent-green/50 transition-colors duration-500"></div>
          </div>
          <h3 class="text-4xl font-serif mb-6">{t('process.step4.title')}</h3>
          <p class="text-xl text-zinc-500 leading-relaxed max-w-xl">{t('process.step4.text')}</p>
        </div>

        <div class="reveal-item group">
          <div class="flex items-center gap-6 mb-8">
            <span class="w-12 h-12 rounded-full bg-accent-pink text-black flex items-center justify-center font-bold font-sans">5</span>
            <div class="h-[1px] flex-grow bg-alabaster/10 group-hover:bg-accent-pink/50 transition-colors duration-500"></div>
          </div>
          <h3 class="text-4xl font-serif mb-6">{t('process.step5.title')}</h3>
          <p class="text-xl text-zinc-500 leading-relaxed max-w-xl">{t('process.step5.text')}</p>
        </div>

        <div class="reveal-item group">
          <div class="flex items-center gap-6 mb-8">
            <span class="w-12 h-12 rounded-full bg-accent-green text-black flex items-center justify-center font-bold font-sans">6</span>
            <div class="h-[1px] flex-grow bg-alabaster/10 group-hover:bg-accent-green/50 transition-colors duration-500"></div>
          </div>
          <h3 class="text-4xl font-serif mb-6">{t('process.step6.title')}</h3>
          <p class="text-xl text-zinc-500 leading-relaxed max-w-xl">{t('process.step6.text')}</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const items = entry.target.querySelectorAll('.reveal-item');
          items.forEach((item, index) => {
            setTimeout(() => {
              item.classList.add('visible');
            }, index * 150);
          });
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal-section').forEach(section => {
      observer.observe(section);
    });
  </script>

  <style>
    .reveal-item {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 1s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .reveal-item.visible {
      opacity: 1;
      transform: translateY(0);
    }
    
    .text-zinc-600 {
      color: #52525b;
    }
  </style>
</BaseLayout>
