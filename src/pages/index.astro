---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalePath } from '../utils/i18n';
import selectedWorks from '../data/selected_works.json';
import { Image } from 'astro:assets';
import { getImageAsset } from '../utils/image-loader';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Resolve images for selected works
const worksWithImages = await Promise.all(
  selectedWorks.map(async (work) => ({
    ...work,
    resolvedImage: work.image ? await getImageAsset(work.image) : null
  }))
);
---

<BaseLayout title="NebulaLab | Creative Developer">
  <section class="max-w-7xl mx-auto px-12 pt-16 pb-32 relative overflow-hidden">
    <div class="max-w-4xl relative">
      <h1 
        class="text-7xl md:text-9xl font-serif tracking-tight mb-12 hero-hide"
        set:html={t('hero.title')}
      />
      
      <p class="text-2xl md:text-3xl text-zinc-400 mb-16 max-w-2xl leading-relaxed font-light hero-hide">
        {t('hero.subtitle')}
      </p>

      <div class="flex flex-wrap items-center gap-8 hero-hide">
        <a href="#work" class="text-sm uppercase tracking-widest font-bold link-hover" aria-label="View recent work">
          {t('hero.view_work')}
        </a>
      </div>
    </div>
  </section>

  <section id="work" class="max-w-7xl mx-auto px-12 py-32 border-t border-alabaster/5">
    <div class="flex justify-between items-end mb-20">
      <h2 class="text-5xl font-serif">{t('work.title')}</h2>
      <a href={getLocalePath("/galleries", lang)} class="text-xs uppercase tracking-[0.2em] font-bold text-zinc-500 hover:text-alabaster transition-colors">{t('work.view_all')}</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {worksWithImages.map((work) => (
        <a href={work.url} target="_blank" rel="noopener noreferrer" class="group relative cursor-pointer overflow-hidden plastic aspect-[4/5] bg-zinc-900 border border-alabaster/5 block">
          <!-- Background Image -->
          <div class="absolute inset-0 bg-linear-to-br from-zinc-800 to-zinc-900 group-hover:scale-105 transition-transform duration-700 ease-out">
            {work.resolvedImage ? (
              <Image src={work.resolvedImage} alt={work.title} width={800} height={1000} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-700" />
            ) : work.image ? (
              <img src={work.image} alt={work.title} width={800} height={1000} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-700" />
            ) : null}
          </div>
          
          <!-- Overlay -->
          <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-10">
            <div class="translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
              <p class="text-xs uppercase tracking-[0.2em] text-zinc-400 mb-3">
                {work.category === 'Web Development' ? t('category.web') : work.category}
              </p>
              <h3 class="text-3xl font-serif text-alabaster">{work.title}</h3>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Process Section -->
  <section class="max-w-7xl mx-auto px-12 py-32 border-t border-alabaster/5">
    <div class="max-w-3xl mb-24">
      <h2 class="text-5xl font-serif mb-8">{t('process.title')}</h2>
      <p class="text-xl text-zinc-400 font-light leading-relaxed">
        {t('process.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-20 gap-y-24">
      {[1, 2, 3, 4, 5, 6].map((step) => (
        <div class="group">
          <div class="text-[10px] uppercase tracking-[0.3em] text-zinc-500 mb-6 font-bold flex items-center gap-4">
            <span class="w-8 h-[1px] bg-zinc-800 group-hover:w-12 group-hover:bg-alabaster transition-all duration-500"></span>
            Step 0{step}
          </div>
          <h3 class="text-2xl font-serif mb-4 text-alabaster group-hover:text-white transition-colors">
            {t(`process.step${step}.title` as any)}
          </h3>
          <p class="text-zinc-400 font-light leading-relaxed">
            {t(`process.step${step}.text` as any)}
          </p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  
  function init() {
    gsap.from('.hero-hide', {
      y: 30,
      opacity: 0,
      duration: 1.2,
      stagger: 0.2,
      ease: 'expo.out',
      delay: 0.5
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
