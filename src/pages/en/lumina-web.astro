---
import BaseLayout from "../../layouts/BaseLayout.astro";

const backHref = "/galleries/web-design";

const palette = [
    { c: "#0B1628", name: "Deep Navy", desc: "Základ" },
    { c: "#122040", name: "Midnight", desc: "Tmavá plocha" },
    { c: "#1E3A6E", name: "Royal Blue", desc: "Akcent" },
    { c: "#C9A84C", name: "Gold", desc: "Zvýraznění" },
    { c: "#E8C97A", name: "Light Gold", desc: "Hover" },
    { c: "#8A9BB5", name: "Muted Blue", desc: "Popis" },
    { c: "#F9F5EC", name: "Cream", desc: "Světlé BG" },
    { c: "#FDFBF7", name: "Off-White", desc: "Základ stránky" },
];

const stats = [
    { n: "+280%", label: "Čas na stránce" },
    { n: "0.9s", label: "Rychlost načítání" },
    { n: "97", label: "Skóre přístupnosti" },
    { n: "3×", label: "Konverzní poměr" },
];

const principles = [
    {
        n: "01",
        title: "Barevná hierarchie",
        body: "Navy jako základ vytváří pocit důvěry a stability. Zlatá se používá cíleně — pouze tam, kde chceme přitáhnout pozornost.",
    },
    {
        n: "02",
        title: "Elegantní typografie",
        body: "Cormorant Garamond pro display nadpisy přináší luxusní, klasický charakter. Inter zajišťuje čitelnost v těle textu.",
    },
    {
        n: "03",
        title: "Negativní prostor",
        body: "Velkorysé odsazení a vzduch okolo prvků zvyšuje vnímání kvality. Přeplněné layouty působí lacině.",
    },
    {
        n: "04",
        title: "Konzistentní rytmus",
        body: "Každá sekce dodržuje jednotný vertikální rytmus. Grid není jen mřížka — je to jazyk, který uživatel nevědomky čte.",
    },
];
---

<BaseLayout title="Lumina — Blue & Gold Design Showcase | Portfolio">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet"
    />

    <div class="lw-root" id="lw-root" data-device="desktop">
        <!-- ═══════════════════════════════════ SWITCHER BAR -->
        <div class="lw-switcher-bar">
            <div class="lw-switcher-inner">
                <span class="lw-switcher-label">Náhled designu</span>
                <div class="lw-switcher-btns">
                    <button
                        class="lw-switcher-btn active"
                        data-switch="desktop"
                    >
                        <svg
                            width="15"
                            height="15"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <rect x="2" y="3" width="20" height="14" rx="2"
                            ></rect>
                            <line x1="8" y1="21" x2="16" y2="21"></line>
                            <line x1="12" y1="17" x2="12" y2="21"></line>
                        </svg>
                        Desktop
                    </button>
                    <button class="lw-switcher-btn" data-switch="mobile">
                        <svg
                            width="15"
                            height="15"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <rect x="5" y="2" width="14" height="20" rx="2"
                            ></rect>
                            <line x1="12" y1="18" x2="12" y2="18.01"></line>
                        </svg>
                        Mobil
                    </button>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════ VIEWPORT WRAPPER -->
        <div class="lw-viewport-container">
            <div class="lw-viewport-frame">
                <!-- BACK LINK -->
                <a href={backHref} class="lw-back">← Zpět na galerii</a>

                <!-- ═══════════════════════════════════ HERO -->
                <section class="lw-hero">
                    <div class="lw-hero-eyebrow">
                        <span class="lw-label">Ukázka designu</span>
                        <span class="lw-label lw-label--muted"
                            >2025 · Blue & Gold Studie</span
                        >
                    </div>

                    <h1 class="lw-hero-title">
                        Elegance<br /><em>ve</em><br />designu.
                    </h1>

                    <div class="lw-hero-aside">
                        <p class="lw-hero-desc">
                            Tato studie prezentuje designový systém postavený na
                            kontrastu hlubokého námořního modrého a zlaté.
                            Kombinace evokuje luxus, profesionalitu a
                            nadčasovost.
                        </p>
                        <a href="#lw-sections" class="lw-btn"
                            >Prozkoumat design ↓</a
                        >
                    </div>
                </section>

                <!-- ═══════════════════════════════════ BROWSER MOCKUP BAND -->
                <div class="lw-band">
                    <div class="lw-band-inner">
                        <div class="lw-mockup-hero">
                            <div class="lw-browser-bar">
                                <span class="lw-dot lw-dot--r"></span>
                                <span class="lw-dot lw-dot--y"></span>
                                <span class="lw-dot lw-dot--g"></span>
                                <div class="lw-urlbar">lumina.studio</div>
                            </div>
                            <div class="lw-mock-page">
                                <div class="lw-mock-nav">
                                    <span class="lw-mock-logo"
                                        >Lumina<span class="lw-mock-logo-dot"
                                            >.</span
                                        >
                                    </span>
                                    <div class="lw-mock-links">
                                        <div class="lw-mock-link"></div>
                                        <div class="lw-mock-link"></div>
                                        <div
                                            class="lw-mock-link lw-mock-link--gold"
                                        >
                                        </div>
                                    </div>
                                </div>
                                <div class="lw-mock-hero-content">
                                    <div class="lw-mock-tag"></div>
                                    <div class="lw-mock-h1"></div>
                                    <div class="lw-mock-h1 lw-mock-h1--short">
                                    </div>
                                    <div class="lw-mock-body"></div>
                                    <div
                                        class="lw-mock-body lw-mock-body--short"
                                    >
                                    </div>
                                    <div class="lw-mock-cta"></div>
                                </div>
                                <div class="lw-mock-image-block"></div>
                            </div>
                        </div>
                        <p class="lw-band-caption">
                            Vizualizace: Desktop náhled webu postaveného na Blue
                            & Gold design systému
                        </p>
                    </div>
                </div>

                <!-- ═══════════════════════════════════ DESIGN SECTIONS -->
                <section class="lw-case" id="lw-sections">
                    <!-- 01 BAREVNÁ PALETA -->
                    <div class="lw-section-block">
                        <div class="lw-section-header">
                            <h2 class="lw-section-title">
                                01 — Barevná paleta
                            </h2>
                            <p class="lw-section-desc">
                                Osmibarvový systém postavený na kontrastu temné
                                námořní modré a teplé zlaté. Každá barva má
                                přesně definovanou roli v hierarchii rozhraní.
                            </p>
                        </div>
                        <div class="lw-palette">
                            {
                                palette.map((sw) => (
                                    <div class="lw-swatch">
                                        <div
                                            class="lw-swatch-color"
                                            style={`background:${sw.c}`}
                                        />
                                        <div class="lw-swatch-info">
                                            <span class="lw-swatch-name">
                                                {sw.name}
                                            </span>
                                            <span class="lw-swatch-desc">
                                                {sw.desc}
                                            </span>
                                            <span class="lw-swatch-hex">
                                                {sw.c}
                                            </span>
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    </div>

                    <!-- 02 TYPOGRAFICKÝ SYSTÉM -->
                    <div class="lw-section-block">
                        <div class="lw-section-header">
                            <h2 class="lw-section-title">
                                02 — Typografický systém
                            </h2>
                            <p class="lw-section-desc">
                                Dva kontrastní typy písma — serif pro
                                reprezentaci a bezpatkový pro čitelnost.
                                Hierarchie o 4 úrovních pokrývá všechny případy
                                užití.
                            </p>
                        </div>
                        <div class="lw-type-showcase">
                            <div class="lw-type-block lw-type-block--dark">
                                <span class="lw-type-label"
                                    >Cormorant Garamond · Display</span
                                >
                                <div class="lw-type-giant">Aa</div>
                                <div class="lw-type-scale">
                                    <span class="lw-type-d1"
                                        >Nadpis Display — 72px</span
                                    >
                                    <span class="lw-type-d2"
                                        >Sekundární nadpis — 40px</span
                                    >
                                    <span class="lw-type-d3"
                                        >Tertiary — 28px</span
                                    >
                                </div>
                            </div>
                            <div class="lw-type-block lw-type-block--light">
                                <span class="lw-type-label-dark"
                                    >Inter · UI & Tělo textu</span
                                >
                                <div class="lw-type-scale-light">
                                    <span class="lw-type-ui1"
                                        >Nadpis sekce — 20px Medium</span
                                    >
                                    <span class="lw-type-ui2"
                                        >Tělo textu — 16px Regular. Používá se
                                        pro odstavce a delší popisky s
                                        dostatečnou řádkovou výškou 1.75.</span
                                    >
                                    <span class="lw-type-ui3"
                                        >Popisek / Label — 11px · 0.15em ·
                                        UPPERCASE</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 03 UI KOMPONENTY -->
                    <div class="lw-section-block">
                        <div class="lw-section-header">
                            <h2 class="lw-section-title">03 — UI Komponenty</h2>
                            <p class="lw-section-desc">
                                Živé ukázky základních stavebních prvků
                                rozhraní. Každá komponenta reflektuje barevný
                                systém a typografický rytmus.
                            </p>
                        </div>
                        <div class="lw-components-grid">
                            <!-- Buttons -->
                            <div class="lw-comp-group">
                                <span class="lw-comp-label">Tlačítka</span>
                                <div class="lw-comp-row">
                                    <button
                                        class="lw-demo-btn lw-demo-btn--primary"
                                        >Primární akce</button
                                    >
                                    <button
                                        class="lw-demo-btn lw-demo-btn--outline"
                                        >Sekundární</button
                                    >
                                    <button
                                        class="lw-demo-btn lw-demo-btn--ghost"
                                        >Ghost</button
                                    >
                                </div>
                                <p class="lw-comp-note">
                                    Zlatá pro primární CTA → maximální kontrast
                                    na tmavém pozadí
                                </p>
                            </div>
                            <!-- Badges -->
                            <div class="lw-comp-group">
                                <span class="lw-comp-label">Štítky & Badge</span
                                >
                                <div class="lw-comp-row">
                                    <span
                                        class="lw-demo-badge lw-demo-badge--gold"
                                        >Design</span
                                    >
                                    <span
                                        class="lw-demo-badge lw-demo-badge--blue"
                                        >Premium</span
                                    >
                                    <span
                                        class="lw-demo-badge lw-demo-badge--outline"
                                        >Studio</span
                                    >
                                </div>
                                <p class="lw-comp-note">
                                    Tři varianty pro různou hierarchii kategorií
                                    a stavů
                                </p>
                            </div>
                            <!-- Input -->
                            <div class="lw-comp-group">
                                <span class="lw-comp-label"
                                    >Formulářové prvky</span
                                >
                                <div class="lw-comp-col">
                                    <input
                                        class="lw-demo-input"
                                        type="text"
                                        placeholder="Váš e-mail"
                                    />
                                    <textarea
                                        class="lw-demo-textarea"
                                        placeholder="Zpráva..."
                                        rows="3"></textarea>
                                </div>
                                <p class="lw-comp-note">
                                    Zlatý focus border — jasný signál aktivního
                                    stavu
                                </p>
                            </div>
                            <!-- Card -->
                            <div class="lw-comp-group">
                                <span class="lw-comp-label">Karta obsahu</span>
                                <div class="lw-demo-card">
                                    <div class="lw-demo-card-tag">
                                        Portfolio
                                    </div>
                                    <h4 class="lw-demo-card-title">
                                        Název projektu
                                    </h4>
                                    <p class="lw-demo-card-text">
                                        Stručný popis projektu nebo služby.
                                        Maximálně dvě věty.
                                    </p>
                                    <a href="#" class="lw-demo-card-link"
                                        >Zobrazit →</a
                                    >
                                </div>
                                <p class="lw-comp-note">
                                    Zlatá čára vlevo signalizuje aktivní nebo
                                    featured stav
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- 04 DESIGNOVÉ PRINCIPY -->
                    <div class="lw-section-block">
                        <div class="lw-section-header">
                            <h2 class="lw-section-title">
                                04 — Designové principy
                            </h2>
                            <p class="lw-section-desc">
                                Čtyři pilíře, na kterých stojí celý vizuální
                                systém. Bez těchto principů by design ztratil
                                svou jednotu.
                            </p>
                        </div>
                        <div class="lw-principle-grid">
                            {
                                principles.map((p) => (
                                    <div class="lw-principle">
                                        <span class="lw-principle-n">
                                            {p.n}
                                        </span>
                                        <h3 class="lw-principle-title">
                                            {p.title}
                                        </h3>
                                        <p class="lw-principle-body">
                                            {p.body}
                                        </p>
                                    </div>
                                ))
                            }
                        </div>
                    </div>

                    <!-- STATS -->
                    <div class="lw-stats">
                        {
                            stats.map((s) => (
                                <div class="lw-stat">
                                    <span class="lw-stat-n">{s.n}</span>
                                    <span class="lw-stat-l">{s.label}</span>
                                </div>
                            ))
                        }
                    </div>

                    <!-- 05 MOBILNÍ DESIGN -->
                    <div class="lw-section-block">
                        <div class="lw-section-header">
                            <h2 class="lw-section-title">
                                05 — Mobilní design
                            </h2>
                            <p class="lw-section-desc">
                                Každý prvek systému je navržen <em
                                    >mobile-first</em
                                >. Na mobilním zařízení design nezdegeneruje —
                                jen se transformuje. Přepněte na „Mobil" v
                                přepínači nahoře a prohlédněte si tuto stránku v
                                rámci smartphone obrazovky.
                            </p>
                        </div>

                        <div class="lw-mobile-callout">
                            <div class="lw-mobile-callout-icon">
                                <svg
                                    width="28"
                                    height="28"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                >
                                    <rect
                                        x="5"
                                        y="2"
                                        width="14"
                                        height="20"
                                        rx="2"></rect>
                                    <line
                                        x1="12"
                                        y1="18"
                                        x2="12"
                                        y2="18.01"
                                        stroke-width="2.5"></line>
                                </svg>
                            </div>
                            <div class="lw-mobile-callout-text">
                                <strong>Vyzkoušejte mobilní náhled</strong>
                                <span
                                    >Přepněte na „Mobil" v přepínači nahoře —
                                    celý design se zobrazí v rámci smartphone
                                    obrazovky (390 × 844 px).</span
                                >
                            </div>
                        </div>

                        <div class="lw-mobile-features">
                            {
                                [
                                    {
                                        title: "Dotykové cíle",
                                        desc: "Minimální velikost 44×44 px pro všechny interaktivní prvky.",
                                    },
                                    {
                                        title: "Vertikální rytmus",
                                        desc: "Sekce se přeskládají do jednoho sloupce bez ztráty hierarchie.",
                                    },
                                    {
                                        title: "Fluid typografie",
                                        desc: "Nadpisy škálují pomocí clamp() — žádný pevný breakpoint.",
                                    },
                                    {
                                        title: "Výkon na mobilech",
                                        desc: "Lazy-load obrázků a minimální JavaScript zajišťují rychlé načítání.",
                                    },
                                ].map((f) => (
                                    <div class="lw-mobile-feat">
                                        <div class="lw-mobile-feat-dot" />
                                        <div>
                                            <strong class="lw-mobile-feat-title">
                                                {f.title}
                                            </strong>
                                            <p class="lw-mobile-feat-desc">
                                                {f.desc}
                                            </p>
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    </div>

                    <!-- CTA ROW -->
                    <div class="lw-cta-row">
                        <p class="lw-cta-text">
                            Zájem o podobný<br /><em>design systém?</em>
                        </p>
                        <a href="/about" class="lw-btn lw-btn--gold"
                            >Napište mi →</a
                        >
                    </div>
                </section>
            </div>
        </div>
    </div>

    <!-- SCRIPTS -->
    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        // ─── INITIAL LOAD ANIMATIONS (HERO) ──────────────────────
        const heroTl = gsap.timeline({
            defaults: { ease: "expo.out", duration: 1.6 }
        });

        heroTl.from(".lw-hero-eyebrow", {
            y: 30,
            opacity: 0,
            duration: 1.2
        })
        .from(".lw-hero-title", {
            y: 60,
            opacity: 0,
            stagger: 0.2
        }, "-=0.9")
        .from(".lw-hero-desc", {
            y: 30,
            opacity: 0
        }, "-=1.2")
        .from(".lw-hero .lw-btn", {
            y: 20,
            opacity: 0
        }, "-=1.4");

        // ─── SCROLL TRIGGERED REVEALS ────────────────────────────
        
        // Mockup Band Reveal
        gsap.from(".lw-mockup-hero", {
            scrollTrigger: {
                trigger: ".lw-band",
                start: "top 80%",
            },
            y: 100,
            opacity: 0,
            duration: 1.5,
            ease: "expo.out"
        });

        // Palette Swatches Stagger
        gsap.from(".lw-swatch", {
            scrollTrigger: {
                trigger: ".lw-palette",
                start: "top 85%",
            },
            y: 40,
            opacity: 0,
            stagger: 0.1,
            duration: 1,
            ease: "power3.out"
        });

        // Type Showcase Reveal
        gsap.from(".lw-type-block", {
            scrollTrigger: {
                trigger: ".lw-type-showcase",
                start: "top 80%",
            },
            x: (i) => i % 2 === 0 ? -50 : 50,
            opacity: 0,
            duration: 1.4,
            ease: "expo.out",
            stagger: 0.2
        });

        // UI Components Grid
        gsap.from(".lw-comp-group", {
            scrollTrigger: {
                trigger: ".lw-components-grid",
                start: "top 80%",
            },
            y: 50,
            opacity: 0,
            stagger: 0.15,
            duration: 1.2,
            ease: "power2.out"
        });

        // Principles Stagger
        gsap.from(".lw-principle", {
            scrollTrigger: {
                trigger: ".lw-principle-grid",
                start: "top 80%",
            },
            y: 40,
            opacity: 0,
            stagger: 0.2,
            duration: 1,
            ease: "power3.out"
        });

        // Stats Counter
        gsap.from(".lw-stat", {
            scrollTrigger: {
                trigger: ".lw-stats",
                start: "top 90%",
            },
            scale: 0.9,
            opacity: 0,
            stagger: 0.1,
            duration: 1,
            ease: "back.out(1.7)"
        });

        // Mockup Parallax
        gsap.to(".lw-mock-image-block", {
            scrollTrigger: {
                trigger: ".lw-band",
                start: "top bottom",
                end: "bottom top",
                scrub: true
            },
            y: -30,
            ease: "none"
        });

        // ─── INTERACTIVE HOVER EFFECTS ───────────────────────────
        
        // Swatches Hover
        const swatches = document.querySelectorAll(".lw-swatch");
        swatches.forEach(swatch => {
            swatch.addEventListener("mouseenter", () => {
                gsap.to(swatch.querySelector(".lw-swatch-color"), {
                    scale: 1.05,
                    duration: 0.4,
                    ease: "power2.out"
                });
            });
            swatch.addEventListener("mouseleave", () => {
                gsap.to(swatch.querySelector(".lw-swatch-color"), {
                    scale: 1,
                    duration: 0.4,
                    ease: "power2.inOut"
                });
            });
        });

        // Demo Buttons Hover Enhancement
        const demoBtns = document.querySelectorAll(".lw-demo-btn");
        demoBtns.forEach(btn => {
            btn.addEventListener("mouseenter", () => {
                gsap.to(btn, {
                    y: -2,
                    boxShadow: "0 10px 20px rgba(0,0,0,0.1)",
                    duration: 0.3
                });
            });
            btn.addEventListener("mouseleave", () => {
                gsap.to(btn, {
                    y: 0,
                    boxShadow: "0 0px 0px rgba(0,0,0,0)",
                    duration: 0.3
                });
            });
        });

        // ─── DEVICE SWITCHER LOGIC ──────────────────────────────
        const root = document.getElementById("lw-root");
        const switcherBtns = document.querySelectorAll(".lw-switcher-btn");
        const viewportFrame = document.querySelector(".lw-viewport-frame");

        switcherBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const device = btn.getAttribute("data-switch");
                const currentDevice = root!.getAttribute("data-device");
                
                if (device === currentDevice) return;

                // Animate transition using GSAP
                const tl = gsap.timeline();

                tl.to(viewportFrame, {
                    opacity: 0,
                    scale: 0.98,
                    duration: 0.3,
                    ease: "power2.inOut",
                    onComplete: () => {
                        root!.setAttribute("data-device", device!);
                        switcherBtns.forEach((b) => b.classList.remove("active"));
                        btn.classList.add("active");
                    }
                })
                .to(viewportFrame, {
                    opacity: 1,
                    scale: 1,
                    duration: 0.5,
                    ease: "expo.out"
                });
            });
        });
    </script>

    <style>
