---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Colors & Theme:
// High-energy vibrant gradients with frosted glass overlays.
---

<BaseLayout title="Aether Digital — Creative Glassmorphism Showcase">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet" />

    <div class="gb-root" id="gb-root" data-device="desktop">
        <!-- ─── SWITCHER ────────────────────────────────────────── -->
        <div class="gb-switcher">
            <div class="gb-switcher-inner">
                <div class="gb-switcher-btns">
                    <button class="gb-switch-btn active" data-switch="desktop">Desktop</button>
                    <button class="gb-switch-btn" data-switch="mobile">Mobile</button>
                </div>
            </div>
        </div>

        <div class="gb-viewport-container">
            <div class="gb-viewport-wrapper">
                <div class="gb-viewport-frame">
                    <div class="gb-mobile-frame-elements">
                        <div class="gb-dynamic-island"></div>
                        <div class="gb-mobile-top-bar">
                            <span>9:41</span>
                            <div class="gb-mobile-icons">
                                <span>📶</span>
                                <span>🔋</span>
                            </div>
                        </div>
                    </div>

                    <a href="/galleries/web-design" class="gb-back">← Back to Gallery</a>
                    
                    <div class="gb-bg-canvas">
                        <div class="gb-blob gb-blob--1"></div>
                        <div class="gb-blob gb-blob--2"></div>
                        <div class="gb-blob gb-blob--3"></div>
                    </div>

                    <div class="gb-container">
                        <!-- ─── HERO ───────────────────────────────────── -->
                        <section class="gb-hero">
                            <div class="gb-glass-card gb-hero-card">
                                <span class="gb-badge">Digital Excellence</span>
                                <h1 class="gb-hero-title">Aether <em>Digital</em></h1>
                                <p class="gb-hero-sub">We craft immersive digital stories through the lens of modern aesthetics.</p>
                                <a href="#about" class="gb-cta">Explore Our Story</a>
                            </div>
                        </section>

                        <!-- ─── ABOUT ──────────────────────────────────── -->
                        <section class="gb-section gb-about" id="about">
                            <div class="gb-glass-card gb-about-card">
                                <h2 class="gb-section-title">The Vision</h2>
                                <p class="gb-text">Aether Digital was founded on the principle that the web should be an experience, not just a destination. We blend high-performance code with avant-garde design to elevate small businesses into global brands.</p>
                                <div class="gb-stats">
                                    <div class="gb-stat"><strong>120+</strong><span>Partners</span></div>
                                    <div class="gb-stat"><strong>15</strong><span>Awards</span></div>
                                </div>
                            </div>
                        </section>

                        <!-- ─── SERVICES ───────────────────────────────── -->
                        <section class="gb-section gb-services">
                            <div class="gb-services-grid">
                                <div class="gb-glass-card gb-service">
                                    <div class="gb-service-icon">✦</div>
                                    <h3>Experience Design</h3>
                                    <p>Creating intuitive flows that lead to conversion.</p>
                                </div>
                                <div class="gb-glass-card gb-service">
                                    <div class="gb-service-icon">⚛</div>
                                    <h3>Creative Code</h3>
                                    <p>Interactive systems built with GSAP and Three.js.</p>
                                </div>
                                <div class="gb-glass-card gb-service">
                                    <div class="gb-service-icon">✺</div>
                                    <h3>Brand Strategy</h3>
                                    <p>Defining the soul of your business in the digital age.</p>
                                </div>
                            </div>
                        </section>

                        <!-- ─── CONTACT ────────────────────────────────── -->
                        <section class="gb-section gb-contact">
                            <div class="gb-glass-card gb-contact-card">
                                <h2 class="gb-section-title">Start Your Journey</h2>
                                <form class="gb-form">
                                    <input type="text" placeholder="Full Name" />
                                    <input type="email" placeholder="Email Address" />
                                    <textarea placeholder="Describe your vision..."></textarea>
                                    <button type="submit" class="gb-submit">Send Message →</button>
                                </form>
                            </div>
                        </section>

                        <footer class="gb-footer">
                            <p>© 2026 Aether Digital / All Rights Reserved</p>
                        </footer>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        // ─── BLOB ANIMATIONS ────────────────────────────────────
        gsap.to(".gb-blob--1", {
            x: "20vw",
            y: "30vh",
            duration: 10,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut"
        });
        gsap.to(".gb-blob--2", {
            x: "-15vw",
            y: "-40vh",
            duration: 12,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut"
        });
        gsap.to(".gb-blob--3", {
            scale: 1.5,
            opacity: 0.6,
            duration: 8,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut"
        });

        // ─── STORYTELLING SCROLL ───────────────────────────────
        const cards = gsap.utils.toArray(".gb-glass-card");
        cards.forEach((card: any, i) => {
            gsap.from(card, {
                opacity: 0,
                y: 100,
                scale: 0.95,
                filter: "blur(20px)",
                duration: 1.2,
                scrollTrigger: {
                    trigger: card,
                    start: "top 85%",
                    end: "top 40%",
                    scrub: 1,
                }
            });
        });

        // ─── SWITCHER LOGIC ─────────────────────────────────────
        const root = document.getElementById("gb-root");
        const switcherBtns = document.querySelectorAll(".gb-switch-btn");
        const viewportFrame = document.querySelector(".gb-viewport-frame");

        switcherBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const device = btn.getAttribute("data-switch");
                const currentDevice = root!.getAttribute("data-device");
                if (device === currentDevice) return;

                gsap.to(viewportFrame, {
                    opacity: 0,
                    scale: 0.98,
                    duration: 0.3,
                    onComplete: () => {
                        root!.setAttribute("data-device", device!);
                        switcherBtns.forEach(b => b.classList.remove("active"));
                        btn.classList.add("active");
                        ScrollTrigger.refresh(true);
                    }
                });
                gsap.to(viewportFrame, {
                    opacity: 1,
                    scale: 1,
                    delay: 0.4,
                    duration: 0.5
                });
            });
        });
    </script>

    <style>
        .gb-root {
            --accent: #FF3BFF;
            --blue: #3B82F6;
            --orange: #F59E0B;
            --glass: rgba(255, 255, 255, 0.1);
            --border: rgba(255, 255, 255, 0.2);
            background: #0f172a;
            color: #fff;
            font-family: 'Outfit', sans-serif;
            overflow-x: hidden;
        }

        /* ─── SWITCHER ────────────────────────────────────────── */
        .gb-switcher {
            position: sticky;
            top: 0;
            z-index: 2000;
            padding: 1rem;
            display: flex;
            justify-content: center;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }
        .gb-switcher-btns {
            display: flex;
            gap: 0.5rem;
            background: rgba(255,255,255,0.05);
            padding: 0.25rem;
            border-radius: 100px;
        }
        .gb-switch-btn {
            border: none;
            padding: 0.6rem 1.4rem;
            border-radius: 100px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            background: transparent;
            color: #ccc;
        }
        .gb-switch-btn.active {
            background: white;
            color: #000;
        }

        /* ─── VIEWPORT ────────────────────────────────────────── */
        .gb-viewport-container {
            display: flex;
            justify-content: center;
            min-height: 100vh;
            padding: 3rem 0;
            background: #060a14;
        }
        .gb-viewport-wrapper {
            width: 100%;
            max-width: 1400px;
            padding: 0 2rem;
            display: flex;
            justify-content: center;
        }
        .gb-viewport-frame {
            width: 100%;
            position: relative;
            background: #0f172a;
            box-shadow: 0 40px 120px rgba(0,0,0,0.5);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            border-radius: 12px;
        }

        /* ─── MOBILE MOCKUP ──────────────────────────────────── */
        .gb-mobile-frame-elements {
            display: none;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 3000;
            padding: 1.2rem 2.5rem;
            pointer-events: none;
        }
        .gb-dynamic-island {
            position: absolute;
            top: 0.8rem;
            left: 50%;
            transform: translateX(-50%);
            width: 110px;
            height: 30px;
            background: #000;
            border-radius: 20px;
        }
        .gb-mobile-top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
            font-weight: 700;
            color: white;
        }
        .gb-mobile-icons {
            display: flex;
            gap: 0.5rem;
            font-size: 0.75rem;
        }

        [data-device="mobile"] .gb-viewport-frame {
            max-width: 390px;
            height: 844px;
            border-radius: 54px;
            border: 12px solid #1a1a1a;
            overflow-y: auto;
            position: relative;
        }
        [data-device="mobile"] .gb-mobile-frame-elements {
            display: block;
        }
        [data-device="mobile"] .gb-viewport-frame::-webkit-scrollbar { display: none; }

        .gb-back {
            position: absolute;
            top: 2rem;
            left: 2rem;
            z-index: 1000;
            color: white;
            text-decoration: none;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            opacity: 0.6;
            transition: opacity 0.3s;
        }
        [data-device="mobile"] .gb-back { top: 4.5rem; left: 1.5rem; font-size: 0.65rem; }
        .gb-back:hover { opacity: 1; }

        /* ─── BACKGROUND CANVAS ─────────────────────────────── */
        .gb-bg-canvas {
            position: absolute;
            inset: 0;
            z-index: 0;
            pointer-events: none;
        }
        .gb-blob {
            position: absolute;
            width: 50vw;
            height: 50vw;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.4;
        }
        .gb-blob--1 { background: var(--accent); top: -10%; left: -10%; }
        .gb-blob--2 { background: var(--blue); bottom: -10%; right: -10%; }
        .gb-blob--3 { background: var(--orange); top: 30%; left: 40%; width: 30vw; height: 30vw; }

        .gb-container {
            position: relative;
            z-index: 10;
        }

        /* ─── GLASS CARDS ────────────────────────────────────── */
        .gb-glass-card {
            background: var(--glass);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border);
            border-radius: 32px;
            padding: 4rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            position: relative;
        }

        /* ─── HERO ───────────────────────────────────────────── */
        .gb-hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 6vw;
        }
        .gb-hero-card {
            max-width: 900px;
            text-align: center;
        }
        .gb-badge {
            display: inline-block;
            background: linear-gradient(90deg, var(--accent), var(--blue));
            padding: 0.4rem 1.2rem;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            margin-bottom: 2rem;
        }
        .gb-hero-title {
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 800;
            line-height: 1;
            margin-bottom: 1.5rem;
            letter-spacing: -0.02em;
        }
        .gb-hero-title em {
            font-style: normal;
            color: transparent;
            -webkit-text-stroke: 1px #fff;
        }
        .gb-hero-sub {
            font-size: 1.25rem;
            color: #cbd5e1;
            max-width: 45ch;
            margin: 0 auto 3rem;
            line-height: 1.6;
        }
        .gb-cta {
            display: inline-block;
            background: white;
            color: #000;
            padding: 1.2rem 3rem;
            border-radius: 100px;
            text-decoration: none;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: transform 0.3s cubic-bezier(0.2, 0, 0.2, 1);
        }
        .gb-cta:hover { transform: scale(1.05); }

        /* ─── SECTIONS ───────────────────────────────────────── */
        .gb-section {
            padding: 10vh 6vw;
            display: flex;
            justify-content: center;
        }
        .gb-section-title {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 2rem;
        }
        .gb-about-card {
            max-width: 1000px;
        }
        .gb-text {
            font-size: 1.4rem;
            line-height: 1.7;
            color: #cbd5e1;
            margin-bottom: 4rem;
        }
        .gb-stats {
            display: flex;
            gap: 4rem;
        }
        .gb-stat strong { font-size: 3rem; display: block; }
        .gb-stat span { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--accent); }

        /* ─── SERVICES ───────────────────────────────────────── */
        .gb-services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            max-width: 1400px;
        }
        .gb-service {
            padding: 3rem;
            text-align: left;
            transition: transform 0.4s, background 0.4s;
        }
        .gb-service:hover {
            transform: translateY(-10px);
            background: rgba(255, 255, 255, 0.15);
        }
        .gb-service-icon {
            font-size: 2.5rem;
            margin-bottom: 1.5rem;
            color: var(--accent);
        }
        .gb-service h3 { font-size: 1.5rem; margin-bottom: 1rem; }
        .gb-service p { color: #cbd5e1; line-height: 1.6; }

        /* ─── CONTACT ────────────────────────────────────────── */
        .gb-contact-card {
            max-width: 800px;
            width: 100%;
        }
        .gb-form {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }
        .gb-form input, .gb-form textarea {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.2rem;
            color: white;
            font-family: inherit;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.3s;
        }
        .gb-form input:focus, .gb-form textarea:focus { border-color: var(--accent); }
        .gb-form textarea { min-height: 150px; resize: none; }
        .gb-submit {
            background: white;
            color: #000;
            padding: 1.2rem;
            border: none;
            border-radius: 16px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: opacity 0.3s;
        }
        .gb-submit:hover { opacity: 0.9; }

        .gb-footer {
            padding: 4rem 0;
            text-align: center;
            font-size: 0.8rem;
            color: #94a3b8;
        }

        /* ─── MOBILE MODS ────────────────────────────────────── */
        [data-device="mobile"] .gb-glass-card { padding: 3rem 1.75rem; border-radius: 28px; }
        [data-device="mobile"] .gb-hero { height: auto; padding: 10rem 1.25rem 5rem; }
        [data-device="mobile"] .gb-hero-title { font-size: 2.8rem; line-height: 1.1; margin-bottom: 1.5rem; }
        [data-device="mobile"] .gb-hero-sub { font-size: 1rem; margin-bottom: 2rem; }
        [data-device="mobile"] .gb-cta { padding: 1rem 2rem; font-size: 0.8rem; }
        
        [data-device="mobile"] .gb-section { padding: 5rem 1.25rem; }
        [data-device="mobile"] .gb-section-title { font-size: 2.2rem; margin-bottom: 1.5rem; }
        [data-device="mobile"] .gb-text { font-size: 1.1rem; margin-bottom: 3rem; }
        [data-device="mobile"] .gb-services-grid { grid-template-columns: 1fr; gap: 1.5rem; }
        [data-device="mobile"] .gb-stats { flex-direction: column; gap: 2.5rem; align-items: center; }
        [data-device="mobile"] .gb-stat strong { font-size: 2.5rem; }
        [data-device="mobile"] .gb-service { padding: 2.5rem; }
        [data-device="mobile"] .gb-submit { font-size: 0.9rem; }
    </style>
</BaseLayout>
