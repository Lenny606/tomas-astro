---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "../utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title="Lumina | Premium Presentation Study">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap"
        rel="stylesheet"
    />

    <div
        class="lumina-wrapper min-h-screen py-20 px-5 relative overflow-hidden"
    >
        <div class="max-w-7xl mx-auto relative z-10">
            <!-- Back to Gallery -->
            <a
                href="/galleries/web-design"
                class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] font-bold text-slate-400 hover:text-[#C0A062] transition-colors mb-16"
            >
                <span class="text-lg">←</span>
                {t("galleries.back")}
            </a>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
                <!-- Left Side: Descriptive Text -->
                <div class="space-y-12 order-2 lg:order-1">
                    <div
                        class="description-card p-12 bg-[#1E293B]/80 backdrop-blur-2xl border border-white/10 rounded-2xl shadow-2xl"
                    >
                        <h2
                            class="text-4xl font-bold mb-10 font-playfair italic text-[#C0A062]"
                        >
                            Obsažené sekce
                        </h2>
                        <ul class="space-y-10">
                            <li class="flex gap-8 group">
                                <span
                                    class="flex-shrink-0 w-10 h-10 border border-[#C0A062] flex items-center justify-center font-bold text-sm text-[#C0A062] transition-transform group-hover:scale-110"
                                    >1</span
                                >
                                <div>
                                    <h3
                                        class="font-bold uppercase tracking-widest text-xs text-slate-400 mb-2"
                                    >
                                        Prestižní Hero
                                    </h3>
                                    <p
                                        class="text-slate-200 font-medium leading-relaxed"
                                    >
                                        Vysokokontrastní záhlaví s elegantní
                                        typografií a zlatými akcenty.
                                    </p>
                                </div>
                            </li>
                            <li class="flex gap-8 group">
                                <span
                                    class="flex-shrink-0 w-10 h-10 border border-[#C0A062] flex items-center justify-center font-bold text-sm text-[#C0A062] transition-transform group-hover:scale-110"
                                    >2</span
                                >
                                <div>
                                    <h3
                                        class="font-bold uppercase tracking-widest text-xs text-slate-400 mb-2"
                                    >
                                        Sekce Služeb
                                    </h3>
                                    <p
                                        class="text-slate-200 font-medium leading-relaxed"
                                    >
                                        Minimalistické karty s hover efekty a
                                        lineárními ikonami.
                                    </p>
                                </div>
                            </li>
                            <li class="flex gap-8 group">
                                <span
                                    class="flex-shrink-0 w-10 h-10 border border-[#C0A062] flex items-center justify-center font-bold text-sm text-[#C0A062] transition-transform group-hover:scale-110"
                                    >3</span
                                >
                                <div>
                                    <h3
                                        class="font-bold uppercase tracking-widest text-xs text-slate-400 mb-2"
                                    >
                                        Interaktivní Prvky
                                    </h3>
                                    <p
                                        class="text-slate-200 font-medium leading-relaxed"
                                    >
                                        Plynulé animace odhalování obsahu při
                                        skrolování (Scroll Reveal).
                                    </p>
                                </div>
                            </li>
                        </ul>
                    </div>

                    <div
                        class="description-card p-12 bg-[#334155]/40 backdrop-blur-md border border-white/5 rounded-2xl shadow-xl"
                    >
                        <h2
                            class="text-3xl font-bold mb-10 font-playfair text-white"
                        >
                            Designové prvky
                        </h2>
                        <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            {
                                [
                                    {
                                        title: "Prémiová paleta",
                                        desc: "Kombinace temně modré a luxusní zlaté.",
                                    },
                                    {
                                        title: "Playfair Display",
                                        desc: "Klasické patkové písmo pro nadpisy.",
                                    },
                                    {
                                        title: "Glassmorphism",
                                        desc: "Využití průhlednosti a rozostření pozadí.",
                                    },
                                    {
                                        title: "Smooth Scroll",
                                        desc: "Plynulá navigace mezi sekcemi.",
                                    },
                                    {
                                        title: "Responsive Design",
                                        desc: "Dokonalé zobrazení na všech zařízeních.",
                                    },
                                    {
                                        title: "Micro-interactions",
                                        desc: "Jemné reakce prvků na interakci uživatele.",
                                    },
                                ].map((feature) => (
                                    <li class="space-y-1">
                                        <h4 class="text-xs font-bold uppercase tracking-widest text-[#C0A062] flex items-center gap-2">
                                            <span class="w-1.5 h-1.5 bg-[#C0A062] rounded-full" />
                                            {feature.title}
                                        </h4>
                                        <p class="text-xs text-slate-300 font-medium leading-relaxed pl-3.5">
                                            {feature.desc}
                                        </p>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>

                <!-- Right Side: The Preview Card (iframe style container or direct render) -->
                <div
                    class="flex justify-center items-start lg:sticky lg:top-20 order-1 lg:order-2"
                >
                    <div
                        class="preview-container relative w-full aspect-[9/16] max-w-[400px] border border-white/20 rounded-[40px] overflow-hidden shadow-[0_32px_64px_-16px_rgba(0,0,0,0.5)] bg-[#0F172A]"
                    >
                        <!-- Embedded design logic -->
                        <div
                            class="preview-content h-full overflow-y-auto custom-scrollbar"
                        >
                            <!-- Hero -->
                            <section
                                class="h-[60vh] flex flex-col items-center justify-center text-center px-6 relative bg-gradient-to-br from-[#0F172A] to-[#1E293B]"
                            >
                                <span
                                    class="text-[10px] tracking-[0.3em] uppercase text-[#C0A062] mb-4"
                                    >Premium Solutions</span
                                >
                                <h2
                                    class="font-playfair text-3xl text-white mb-6 leading-tight"
                                >
                                    Crafting <span class="italic text-[#C0A062]"
                                        >Digital</span
                                    ><br />Experiences
                                </h2>
                                <p class="text-slate-400 text-sm mb-10">
                                    We transform visionary ideas into elegant
                                    digital solutions.
                                </p>
                                <div class="flex flex-col gap-4 w-full px-12">
                                    <div
                                        class="py-3 bg-[#C0A062] text-[#0F172A] text-xs font-bold tracking-widest uppercase"
                                    >
                                        Discover
                                    </div>
                                    <div
                                        class="py-3 border border-slate-500 text-white text-xs font-bold tracking-widest uppercase"
                                    >
                                        Contact
                                    </div>
                                </div>
                            </section>

                            <!-- About Mini -->
                            <section class="p-10 bg-[#1E293B]">
                                <span
                                    class="text-[9px] tracking-[0.2em] uppercase text-[#C0A062] mb-3 block"
                                    >Who We Are</span
                                >
                                <h3
                                    class="font-playfair text-xl text-white mb-4"
                                >
                                    Excellence in Innovation
                                </h3>
                                <p
                                    class="text-slate-400 text-xs leading-relaxed"
                                >
                                    We push the boundaries of digital innovation
                                    combining artistry with technical precision.
                                </p>
                            </section>

                            <!-- Services Mini -->
                            <section class="p-10 bg-[#0F172A]">
                                <div class="grid grid-cols-2 gap-4">
                                    <div
                                        class="p-6 bg-[#1E293B] border border-white/5"
                                    >
                                        <div
                                            class="w-6 h-6 border border-[#C0A062] mb-4"
                                        >
                                        </div>
                                        <h4
                                            class="text-white text-[10px] font-bold uppercase tracking-wider"
                                        >
                                            Strategy
                                        </h4>
                                    </div>
                                    <div
                                        class="p-6 bg-[#1E293B] border border-white/5"
                                    >
                                        <div
                                            class="w-6 h-6 border border-[#C0A062] mb-4"
                                        >
                                        </div>
                                        <h4
                                            class="text-white text-[10px] font-bold uppercase tracking-wider"
                                        >
                                            Design
                                        </h4>
                                    </div>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .lumina-wrapper {
            background-color: #0f172a;
            color: #f8fafc;
            font-family: "Inter", sans-serif;
        }
        .font-playfair {
            font-family: "Playfair Display", serif;
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #0f172a;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #c0a062;
            border-radius: 10px;
        }
    </style>
</BaseLayout>
