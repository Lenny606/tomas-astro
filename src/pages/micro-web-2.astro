---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "../utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title="Alex Creator | Fluid Glassmorphism Study">
    <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,700&family=Outfit:wght@400;500;600&display=swap"
        rel="stylesheet"
    />

    <div
        class="fluid-glass-wrapper min-h-screen py-20 px-5 relative overflow-hidden"
    >
        <!-- Background Blobs -->
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>

        <div class="max-w-7xl mx-auto relative z-10">
            <!-- Back to Gallery -->
            <a
                href="/galleries/web-design"
                class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] font-bold text-slate-500 hover:text-indigo-600 transition-colors mb-16"
            >
                <span class="text-lg">←</span>
                {t("galleries.back")}
            </a>

            <div
                id="main-grid"
                class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start transition-all duration-700"
            >
                <!-- Left Side: Descriptive Text -->
                <div
                    class="description-sidebar space-y-12 order-2 lg:order-1 transition-all duration-500 overflow-hidden"
                >
                    <div
                        class="description-card p-12 bg-white/20 backdrop-blur-2xl border border-white/50 rounded-[40px] shadow-[0_32px_64px_-16px_rgba(99,102,241,0.2)]"
                    >
                        <h2
                            class="text-4xl font-bold mb-10 font-fraunces italic bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent"
                        >
                            Obsažené sekce
                        </h2>
                        <ul class="space-y-10">
                            <li class="flex gap-8 group">
                                <span
                                    class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-purple-400 to-indigo-500 rounded-2xl flex items-center justify-center font-bold text-sm text-white shadow-lg transition-transform group-hover:scale-110"
                                    >1</span
                                >
                                <div>
                                    <h3
                                        class="font-bold uppercase tracking-widest text-xs text-indigo-900/60 mb-2"
                                    >
                                        Hero / Profile
                                    </h3>
                                    <p
                                        class="text-slate-700 font-medium leading-relaxed"
                                    >
                                        Morfující se organický avatar, jméno s
                                        přechodem a skleněný odznak role.
                                    </p>
                                </div>
                            </li>
                            <li class="flex gap-8 group">
                                <span
                                    class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-pink-400 to-rose-500 rounded-2xl flex items-center justify-center font-bold text-sm text-white shadow-lg transition-transform group-hover:scale-110"
                                    >2</span
                                >
                                <div>
                                    <h3
                                        class="font-bold uppercase tracking-widest text-xs text-indigo-900/60 mb-2"
                                    >
                                        Bio / Intro
                                    </h3>
                                    <p
                                        class="text-slate-700 font-medium leading-relaxed"
                                    >
                                        Karta s jemným skleněným efektem a
                                        vycentrovaným textem na rozostřeném
                                        pozadí.
                                    </p>
                                </div>
                            </li>
                            <li class="flex gap-8 group">
                                <span
                                    class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-sky-400 to-indigo-500 rounded-2xl flex items-center justify-center font-bold text-sm text-white shadow-lg transition-transform group-hover:scale-110"
                                    >3</span
                                >
                                <div>
                                    <h3
                                        class="font-bold uppercase tracking-widest text-xs text-indigo-900/60 mb-2"
                                    >
                                        Rychlé odkazy
                                    </h3>
                                    <p
                                        class="text-slate-700 font-medium leading-relaxed"
                                    >
                                        Interaktivní tlačítka s plynulou animací
                                        barevné výplně při přejetí myší.
                                    </p>
                                </div>
                            </li>
                            <li class="flex gap-8 group">
                                <span
                                    class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center font-bold text-sm text-white shadow-lg transition-transform group-hover:scale-110"
                                    >4</span
                                >
                                <div>
                                    <h3
                                        class="font-bold uppercase tracking-widest text-xs text-indigo-900/60 mb-2"
                                    >
                                        Ukázky prací
                                    </h3>
                                    <p
                                        class="text-slate-700 font-medium leading-relaxed"
                                    >
                                        Zaoblené karty s efektem přiblížení a
                                        dynamickým popiskem v dolní části.
                                    </p>
                                </div>
                            </li>
                        </ul>
                    </div>

                    <div
                        class="description-card p-12 bg-white/40 backdrop-blur-md border border-white/60 rounded-[40px] shadow-[0_24px_48px_rgba(99,102,241,0.15)] overflow-hidden relative group"
                    >
                        <div
                            class="absolute inset-0 bg-gradient-to-br from-indigo-600/5 to-purple-600/5 -z-10 group-hover:scale-110 transition-transform duration-500"
                        >
                        </div>
                        <h2
                            class="text-3xl font-bold mb-10 font-fraunces text-indigo-950"
                        >
                            Designové prvky
                        </h2>
                        <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            {
                                [
                                    {
                                        title: "Fluidní skleněný efekt",
                                        desc: "Pokročilé rozostření (backdrop-filter) pro hloubku.",
                                    },
                                    {
                                        title: "Morfující organické tvary",
                                        desc: "Avatar i pozadí s plynulou animací geometrie.",
                                    },
                                    {
                                        title: "Pastelová barevná paleta",
                                        desc: "Jemné snové gradienty v tónech fialové a růžové.",
                                    },
                                    {
                                        title: "Barevné stíny a záře",
                                        desc: "Využití odstínů gradientu pro měkké vyznění prvků.",
                                    },
                                    {
                                        title: "Prémiová typografie",
                                        desc: "Spojení Outfit (sans) a Fraunces (serif).",
                                    },
                                    {
                                        title: "Plovoucí pozadí (Blobs)",
                                        desc: "Animované elementy na pozadí tvoří pocit pohybu.",
                                    },
                                ].map((feature) => (
                                    <li class="space-y-1">
                                        <h4 class="text-xs font-bold uppercase tracking-widest text-indigo-600 flex items-center gap-2">
                                            <span class="w-1.5 h-1.5 bg-indigo-500 rounded-full" />
                                            {feature.title}
                                        </h4>
                                        <p class="text-xs text-slate-600 font-medium leading-relaxed pl-3.5">
                                            {feature.desc}
                                        </p>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>

                <!-- Right Side: The Preview area -->
                <div
                    class="flex flex-col items-center lg:sticky lg:top-20 order-1 lg:order-2 space-y-8"
                >
                    <!-- Device Switcher -->
                    <div
                        class="device-switcher p-1.5 bg-white/20 backdrop-blur-xl border border-white/50 rounded-2xl shadow-lg flex gap-1 relative z-20"
                    >
                        <button
                            class="switcher-btn active px-6 py-2.5 rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-300 flex items-center gap-2"
                            data-mode="mobile"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect
                                    x="5"
                                    y="2"
                                    width="14"
                                    height="20"
                                    rx="2"
                                    ry="2"></rect><line
                                    x1="12"
                                    y1="18"
                                    x2="12.01"
                                    y2="18"></line>
                            </svg>
                            Mobile
                        </button>
                        <button
                            class="switcher-btn px-6 py-2.5 rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-300 flex items-center gap-2"
                            data-mode="desktop"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect
                                    x="2"
                                    y="3"
                                    width="20"
                                    height="14"
                                    rx="2"
                                    ry="2"></rect><line
                                    x1="8"
                                    y1="21"
                                    x2="16"
                                    y2="21"></line><line
                                    x1="12"
                                    y1="17"
                                    x2="12"
                                    y2="21"></line>
                            </svg>
                            Desktop
                        </button>
                    </div>

                    <div
                        id="preview-wrapper"
                        class="preview-wrapper mode-mobile w-full transition-all duration-500 ease-in-out flex justify-center"
                    >
                        <div
                            class="container relative transition-all duration-500 overflow-hidden"
                        >
                            <!-- Desktop Nav (Inside Preview) -->
                            <nav class="desktop-nav-internal">
                                <div class="nav-logo font-fraunces">AC</div>
                                <div class="nav-links">
                                    <a href="#">Domů</a>
                                    <a href="#">Práce</a>
                                    <a href="#">O mně</a>
                                    <a href="#" class="nav-cta">Kontakt</a>
                                </div>
                            </nav>

                            <!-- Hero Section -->
                            <section class="hero">
                                <div class="hero-content">
                                    <div class="avatar-wrapper">AC</div>
                                    <div class="hero-text">
                                        <h1 class="font-fraunces">
                                            Alex Creator
                                        </h1>
                                        <span class="role-badge"
                                            >Digitální umělec a vývojář</span
                                        >
                                    </div>
                                </div>
                            </section>

                            <!-- Bio Section -->
                            <section class="bio">
                                <p>
                                    Vytvářím chaos pomocí kódu a barev. Buduji
                                    digitální zážitky, které přinášejí radost a
                                    překonávají konvence. Podívejte se na mé
                                    nejnovější experimenty níže!
                                </p>
                            </section>

                            <!-- Main Layout Grid (Desktop optimization) -->
                            <div class="desktop-main-grid">
                                <!-- Links Section -->
                                <section class="links-section">
                                    <h2 class="section-title font-fraunces">
                                        Rychlé odkazy
                                    </h2>
                                    <div class="links-grid">
                                        <a href="#" class="link-btn">
                                            Zobrazit portfolio 2024
                                            <span class="arrow">→</span>
                                        </a>
                                        <a href="#" class="link-btn">
                                            Přečíst si případovou studii
                                            <span class="arrow">→</span>
                                        </a>
                                        <a href="#" class="link-btn">
                                            Objednat si konzultaci
                                            <span class="arrow">→</span>
                                        </a>
                                        <a href="#" class="link-btn">
                                            Stáhnout zdroje zdarma
                                            <span class="arrow">→</span>
                                        </a>
                                    </div>
                                </section>

                                <!-- Content Grid Section -->
                                <section class="content-grid">
                                    <h2 class="section-title font-fraunces">
                                        Nejnovější práce
                                    </h2>
                                    <div class="grid-container">
                                        <div class="grid-item group/item">
                                            <img
                                                src="https://picsum.photos/seed/fluid1/300/300"
                                                alt="Project 1"
                                            />
                                            <div class="overlay">
                                                Identita značky
                                            </div>
                                        </div>
                                        <div class="grid-item group/item">
                                            <img
                                                src="https://picsum.photos/seed/fluid2/300/300"
                                                alt="Project 2"
                                            />
                                            <div class="overlay">
                                                Webový design
                                            </div>
                                        </div>
                                        <div class="grid-item group/item">
                                            <img
                                                src="https://picsum.photos/seed/fluid3/300/300"
                                                alt="Project 3"
                                            />
                                            <div class="overlay">3D umění</div>
                                        </div>
                                        <div class="grid-item group/item">
                                            <img
                                                src="https://picsum.photos/seed/fluid4/300/300"
                                                alt="Project 4"
                                            />
                                            <div class="overlay">
                                                Motion design
                                            </div>
                                        </div>
                                    </div>
                                </section>
                            </div>

                            <div class="desktop-footer-row">
                                <!-- Newsletter Section -->
                                <section class="newsletter">
                                    <h3 class="font-fraunces">
                                        Přidejte se k týmu
                                    </h3>
                                    <p>
                                        Získejte týdenní tipy na design, zdroje
                                        zdarma a pohled do zákulisí.
                                    </p>
                                    <form
                                        class="newsletter-form"
                                        onsubmit="event.preventDefault(); alert('Díky za odběr!');"
                                    >
                                        <input
                                            type="email"
                                            class="newsletter-input"
                                            placeholder="vase@email.cz"
                                            required
                                        />
                                        <button
                                            type="submit"
                                            class="newsletter-btn"
                                            >Přidat se</button
                                        >
                                    </form>
                                </section>

                                <!-- Social Footer -->
                                <footer class="social-footer">
                                    <div class="social-icons">
                                        <a
                                            href="#"
                                            class="social-icon instagram"
                                            title="Instagram"
                                        >
                                            <svg
                                                width="20"
                                                height="20"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                                ><path
                                                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                                                ></path>
                                            </svg>
                                        </a>
                                        <a
                                            href="#"
                                            class="social-icon twitter"
                                            title="Twitter"
                                        >
                                            <svg
                                                width="20"
                                                height="20"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                                ><path
                                                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                                                ></path>
                                            </svg>
                                        </a>
                                        <a
                                            href="#"
                                            class="social-icon linkedin"
                                            title="LinkedIn"
                                        >
                                            <svg
                                                width="20"
                                                height="20"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                                ><path
                                                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                                                ></path>
                                            </svg>
                                        </a>
                                    </div>
                                    <p class="footer-text">
                                        © 2024 Alex Creator.
                                    </p>
                                </footer>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            const btns = document.querySelectorAll(".switcher-btn");
            const wrapper = document.getElementById("preview-wrapper");

            btns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const mode = btn.dataset.mode;
                    const mainGrid = document.getElementById("main-grid");

                    // Update active state
                    btns.forEach((b) => b.classList.remove("active"));
                    btn.classList.add("active");

                    // Update wrapper mode
                    wrapper.classList.remove("mode-mobile", "mode-desktop");
                    wrapper.classList.add(`mode-${mode}`);

                    // Global layout transformation
                    if (mode === "desktop") {
                        mainGrid.classList.add("preview-mode-desktop");
                    } else {
                        mainGrid.classList.remove("preview-mode-desktop");
                    }
                });
            });
        });
    </script>

    <style>
        /* Switcher Styles */
        .device-switcher {
            margin-bottom: 1rem;
        }
        .switcher-btn {
            color: var(--text-secondary);
            background: transparent;
            cursor: pointer;
            border: none;
        }
        .switcher-btn.active {
            background: white;
            color: var(--text-primary);
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
        }
        .switcher-btn:not(.active):hover {
            background: rgba(255, 255, 255, 0.3);
        }

        /* Preview Wrapper Transition Logic */
        .preview-wrapper.mode-mobile .container {
            max-width: 420px;
        }
        .preview-wrapper.mode-desktop .container {
            max-width: 1400px; /* Fully expanded for immersive view */
            border-radius: 48px;
            padding: 0; /* Nav handles inner padding */
        }

        /* Desktop Internal Navbar */
        .desktop-nav-internal {
            display: none;
            padding: 30px 60px;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--glass-border);
            margin-bottom: 40px;
        }
        .mode-desktop .desktop-nav-internal {
            display: flex;
        }
        .nav-logo {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-primary);
        }
        .nav-links {
            display: flex;
            gap: 40px;
            align-items: center;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 600;
            transition: color 0.3s ease;
        }
        .nav-links a:hover {
            color: var(--text-primary);
        }
        .nav-cta {
            background: var(--gradient-primary);
            color: white !important;
            padding: 10px 24px;
            border-radius: 12px;
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.2);
        }

        /* Desktop Layout Adaptations */
        .mode-desktop .container > section {
            padding-left: 60px;
            padding-right: 60px;
        }
        .mode-desktop .hero-content {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 40px;
            text-align: left;
        }
        .mode-desktop .avatar-wrapper {
            margin: 0;
            width: 150px;
            height: 150px;
        }
        .mode-desktop .hero h1 {
            font-size: 48px;
            margin-bottom: 8px;
        }

        .mode-desktop .desktop-main-grid {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 40px;
            margin-top: 20px;
        }

        .mode-desktop .links-grid {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .mode-desktop .grid-container {
            grid-template-columns: repeat(4, 1fr);
        }

        .mode-desktop .desktop-footer-row {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 40px;
            align-items: center;
        }

        .mode-desktop .newsletter {
            margin-bottom: 0;
            margin-top: 20px;
        }
        .mode-desktop .social-footer {
            margin-top: 0;
        }

        /* Global Layout Transformation */
        .preview-mode-desktop {
            grid-template-columns: 1fr !important;
        }
        .preview-mode-desktop .description-sidebar {
            opacity: 0;
            max-height: 0;
            margin: 0 !important;
            padding: 0 !important;
            pointer-events: none;
        }

        .fluid-glass-wrapper {
            --bg-base: #faf9f6;
            --glass-bg: rgba(255, 255, 255, 0.35);
            --glass-border: rgba(255, 255, 255, 0.6);
            --text-primary: #1e293b;
            --text-secondary: #475569;
            --gradient-primary: linear-gradient(
                135deg,
                #c084fc 0%,
                #6366f1 100%
            );
            --gradient-secondary: linear-gradient(
                135deg,
                #f472b6 0%,
                #fb7185 100%
            );
            --gradient-accent: linear-gradient(
                135deg,
                #38bdf8 0%,
                #818cf8 100%
            );
            --shadow-soft: 0 10px 40px -10px rgba(99, 102, 241, 0.25);
            --shadow-glow: 0 0 30px rgba(192, 132, 252, 0.3);

            font-family: "Outfit", sans-serif;
            background: var(--bg-base);
            color: var(--text-primary);
        }

        .font-fraunces {
            font-family: "Fraunces", serif;
        }

        /* Animated Background Blobs */
        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            z-index: 1;
            animation: blobFloat 20s ease-in-out infinite;
        }

        .blob-1 {
            width: 400px;
            height: 400px;
            background: var(--gradient-primary);
            top: -100px;
            left: -100px;
            animation-delay: 0s;
        }

        .blob-2 {
            width: 350px;
            height: 350px;
            background: var(--gradient-secondary);
            bottom: 20%;
            right: -50px;
            animation-delay: -5s;
        }

        .blob-3 {
