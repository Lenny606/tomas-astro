---
import BaseLayout from "../layouts/BaseLayout.astro";

// Image paths (generated assets)
const heroImg = "/images/vanguard/vanguard_hero_fashion_1773681135767.png";
const product1Img = "/images/vanguard/vanguard_product_1_1773681153161.png";
const product2Img = "/images/vanguard/vanguard_product_2_1773681167581.png";

---

<BaseLayout title="Vanguard Fashion — Avant-Garde Showcase">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Manrope:wght@300;400;500;700&display=swap" rel="stylesheet" />

    <div class="vf-root" id="vf-root" data-device="desktop">
        <!-- ─── SWITCHER BAR ──────────────────────────────────────── -->
        <div class="vf-switcher-bar">
            <div class="vf-switcher-inner">
                <span class="vf-switcher-label">Náhled designu</span>
                <div class="vf-switcher-btns">
                    <button class="vf-switcher-btn active" data-switch="desktop">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                            <line x1="8" y1="21" x2="16" y2="21"></line>
                            <line x1="12" y1="17" x2="12" y2="21"></line>
                        </svg>
                        Desktop
                    </button>
                    <button class="vf-switcher-btn" data-switch="mobile">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="5" y="2" width="14" height="20" rx="2"></rect>
                            <line x1="12" y1="18" x2="12" y2="18.01"></line>
                        </svg>
                        Mobil
                    </button>
                </div>
            </div>
        </div>

        <!-- ─── VIEWPORT WRAPPER ──────────────────────────────────── -->
        <div class="vf-viewport-container">
            <div class="vf-viewport-frame">
                <a href="/galleries/web-design" class="vf-back">← Zpět na galerii</a>
                
                <div class="vf-container">
        <!-- ─── HERO SECTION ───────────────────────────────────── -->
        <section class="vf-hero">
            <div class="vf-hero-bg">
                <img src={heroImg} alt="Vanguard Fashion Hero" class="vf-hero-img" />
                <div class="vf-hero-overlay"></div>
            </div>
            <div class="vf-hero-content">
                <div class="vf-hero-eyebrow">Collection 2026</div>
                <h1 class="vf-hero-title">
                    <span class="vf-title-line">VANGUARD</span>
                    <span class="vf-title-line vf-title-italic">SYSTEMS</span>
                </h1>
                <p class="vf-hero-tagline">Redefining the boundaries of wearable architecture.</p>
                <div class="vf-hero-cta">
                    <a href="#collection" class="vf-btn vf-btn--outline">Explore Archive</a>
                </div>
            </div>
        </section>

        <!-- ─── PHILOSOPHY ─────────────────────────────────────── -->
        <section class="vf-philosophy">
            <div class="vf-phil-grid">
                <div class="vf-phil-text">
                    <h2 class="vf-phil-title">The Future is<br/><em>Resilient</em></h2>
                    <p class="vf-phil-body">
                        Our designs prioritize function over decoration, integrating tactile materials with high-performance silhouettes. Every stitch serves a purpose in the urban landscape.
                    </p>
                </div>
                <div class="vf-phil-visual">
                    <div class="vf-reveal-wrapper">
                        <img src={product1Img} alt="Leather Detail" class="vf-reveal-img" />
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── HORIZONTAL SCROLL SECTION ───────────────────────── -->
        <section class="vf-horizontal-wrap" id="collection">
            <div class="vf-horizontal-scroll">
                <div class="vf-horizontal-inner">
                    <!-- Slide 1 -->
                    <div class="vf-slide vf-slide--intro">
                        <div class="vf-slide-label">01 / Archives</div>
                        <h2 class="vf-slide-title">Tactility</h2>
                    </div>
                    <!-- Slide 2 -->
                    <div class="vf-slide vf-slide--product">
                        <div class="vf-product-card">
                            <img src={product2Img} alt="SNEAKER V1" class="vf-product-img" />
                            <div class="vf-product-info">
                                <h3>SNEAKER V1</h3>
                                <p>Kinetic propulsion sole system.</p>
                            </div>
                        </div>
                    </div>
                    <!-- Slide 3 -->
                    <div class="vf-slide vf-slide--info">
                        <div class="vf-info-block">
                             <div class="vf-info-label">Materiality</div>
                             <p>Using 100% recycled nylon and lab-grown leathers to create a sustainable future for techwear enthusiasts worldwide.</p>
                        </div>
                    </div>
                     <!-- Slide 4 -->
                    <div class="vf-slide vf-slide--product">
                         <div class="vf-product-card">
                            <img src={product1Img} alt="JACKET 03" class="vf-product-img" />
                            <div class="vf-product-info">
                                <h3>JACKET 03</h3>
                                <p>Modular weather-shield layering.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── FOOTER CTA ──────────────────────────────────────── -->
        <section class="vf-cta-section">
            <div class="vf-cta-content">
                 <h2 class="vf-cta-title">Join the System</h2>
                 <form class="vf-form">
                     <input type="email" placeholder="Your Entry Point (Email)" class="vf-input" />
                     <button type="submit" class="vf-submit">Connect →</button>
                 </form>
            </div>
        </section>
                </div> <!-- vf-container ends -->
            </div> <!-- vf-viewport-frame ends -->
        </div> <!-- vf-viewport-container ends -->
    </div> <!-- vf-root ends -->

    <!-- SCRIPTS -->
    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        // ─── HERO ANIMATION ────────────────────────────────────
        const heroTl = gsap.timeline({ defaults: { ease: "power4.out", duration: 2 }});

        heroTl.from(".vf-hero-img", {
            scale: 1.2,
            duration: 3,
            ease: "expo.out"
        })
        .from(".vf-hero-overlay", {
            opacity: 0,
            duration: 2
        }, "<")
        .from(".vf-title-line", {
            y: 100,
            opacity: 0,
            stagger: 0.2,
            skewY: 5
        }, "-=2")
        .from(".vf-hero-eyebrow, .vf-hero-tagline, .vf-hero-cta", {
            y: 30,
            opacity: 0,
            stagger: 0.1
        }, "-=1.5");

        // ─── PHILOSOPHY REVEAL ─────────────────────────────────
        gsap.from(".vf-phil-text h2, .vf-phil-text p", {
            scrollTrigger: {
                trigger: ".vf-philosophy",
                start: "top 70%",
            },
            y: 50,
            opacity: 0,
            stagger: 0.2,
            duration: 1.2
        });

        gsap.from(".vf-reveal-wrapper", {
            scrollTrigger: {
                trigger: ".vf-philosophy",
                start: "top 60%",
            },
            clipPath: "inset(0 100% 0 0)",
            duration: 1.5,
            ease: "expo.inOut"
        });

        // ─── HORIZONTAL SCROLL ─────────────────────────────────
        const horizontalSection = document.querySelector(".vf-horizontal-scroll");
        const horizontalInner = document.querySelector(".vf-horizontal-inner");

        if (horizontalSection && horizontalInner) {
            const scrollAmount = horizontalInner.scrollWidth - window.innerWidth;

            gsap.to(horizontalInner, {
                x: -scrollAmount,
                ease: "none",
                scrollTrigger: {
                    trigger: ".vf-horizontal-wrap",
                    pin: true,
                    scrub: 1,
                    end: () => "+=" + (scrollAmount + window.innerWidth),
                    invalidateOnRefresh: true,
                }
            });
        }

        // ─── DEVICE SWITCHER LOGIC ──────────────────────────────
        const root = document.getElementById("vf-root");
        const switcherBtns = document.querySelectorAll(".vf-switcher-btn");
        const viewportFrame = document.querySelector(".vf-viewport-frame");

        switcherBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const device = btn.getAttribute("data-switch");
                const currentDevice = root!.getAttribute("data-device");
                
                if (device === currentDevice) return;

                const tl = gsap.timeline();
                tl.to(viewportFrame, {
                    opacity: 0,
                    scale: 0.98,
                    duration: 0.3,
                    ease: "power2.inOut",
                    onComplete: () => {
                        root!.setAttribute("data-device", device!);
                        switcherBtns.forEach((b) => b.classList.remove("active"));
                        btn.classList.add("active");
                        ScrollTrigger.refresh();
                    }
                })
                .to(viewportFrame, {
                    opacity: 1,
                    scale: 1,
                    duration: 0.5,
                    ease: "expo.out"
                });
            });
        });
    </script>

    <style>
        .vf-root {
            --black: #000;
            --white: #fff;
            --accent: #0047FF;
            --gray: #111;
            --muted: #666;
            background: var(--black);
            color: var(--white);
            font-family: 'Manrope', sans-serif;
        }

        /* ─── SWITCHER BAR ──────────────────────────────────────── */
        .vf-switcher-bar {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 0.75rem 1.5rem;
            display: flex;
            justify-content: center;
        }
        .vf-switcher-inner {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }
        .vf-switcher-label {
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            color: var(--muted);
            text-transform: uppercase;
        }
        .vf-switcher-btns {
            display: flex;
            background: rgba(255, 255, 255, 0.06);
            padding: 0.2rem;
            border-radius: 100px;
            gap: 0.2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .vf-switcher-btn {
            border: none;
            background: transparent;
            padding: 0.4rem 1.1rem;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .vf-switcher-btn.active {
            background: var(--white);
            color: var(--black);
        }

        /* ─── VIEWPORT ──────────────────────────────────────────── */
        .vf-viewport-container {
            display: flex;
            justify-content: center;
            min-height: 100vh;
            background: var(--black);
            transition: background 0.5s;
        }
        .vf-viewport-frame {
            width: 100%;
            background: var(--black);
            position: relative;
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
        [data-device="mobile"] .vf-viewport-container {
            padding: 3rem 1.5rem 5rem;
            background: #080808;
        }
        [data-device="mobile"] .vf-viewport-frame {
            max-width: 390px;
            height: 844px;
            border: 10px solid #181818;
            border-radius: 54px;
            overflow-y: auto;
            overflow-x: hidden;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.9), inset 0 0 0 2px rgba(255,255,255,0.05);
            box-sizing: border-box;
            position: relative;
        }

        /* Dynamic Island Simulation */
        [data-device="mobile"] .vf-viewport-frame::before {
            content: "";
            position: sticky;
            top: 12px;
            left: 50%;
            transform: translateX(-50%);
            width: 110px;
            height: 30px;
            background: #000;
            border-radius: 20px;
            z-index: 1000;
            pointer-events: none;
            display: block;
        }

        [data-device="mobile"] .vf-viewport-frame::-webkit-scrollbar {
            width: 0;
        }

        .vf-back {
            display: inline-block;
            margin: 2rem 6vw;
            font-size: 0.65rem;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--muted);
            text-decoration: none;
            transition: color 0.25s;
        }
        .vf-back:hover { color: var(--accent); }
        [data-device="mobile"] .vf-back { margin: 2rem 1.5rem 0.5rem; }

        .vf-container {
            background: var(--black);
            color: var(--white);
            overflow-x: hidden;
        }

        /* ─── HERO ───────────────────────────────────────────── */
        .vf-hero {
            height: 100vh;
            width: 100%;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        /* Mobile refinement for Hero */
        [data-device="mobile"] .vf-hero { height: 80vh; padding-top: 2rem; }

        .vf-hero-bg {
            position: absolute;
            inset: 0;
            z-index: 1;
        }
        .vf-hero-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        [data-device="mobile"] .vf-hero-img { object-position: 70% center; } /* Show more model face */

        .vf-hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,0.9));
        }
        .vf-hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: 0 1.5rem;
        }
        .vf-hero-eyebrow {
            font-size: 0.75rem;
            letter-spacing: 0.5em;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 2rem;
        }
        [data-device="mobile"] .vf-hero-eyebrow { font-size: 0.6rem; letter-spacing: 0.3em; margin-bottom: 1.5rem; }

        .vf-hero-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(3.5rem, 12vw, 10rem);
            line-height: 0.85;
            font-weight: 800;
            display: flex;
            flex-direction: column;
            margin-bottom: 2rem;
        }
        [data-device="mobile"] .vf-hero-title { font-size: 3.8rem; line-height: 0.8; margin-bottom: 1.5rem; }

        .vf-title-italic {
            font-style: italic;
            -webkit-text-stroke: 1px var(--white);
            color: transparent;
        }
        .vf-hero-tagline {
            font-size: 1.1rem;
            color: var(--muted);
            max-width: 40ch;
            margin: 0 auto 3rem;
        }
        [data-device="mobile"] .vf-hero-tagline { font-size: 0.85rem; max-width: 30ch; margin-bottom: 2.5rem; line-height: 1.5; }

        .vf-btn {
            display: inline-block;
            padding: 1.25rem 3.5rem;
            border: 1px solid var(--white);
            color: var(--white);
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            transition: background 0.3s, color 0.3s;
        }
        [data-device="mobile"] .vf-btn { padding: 1rem 2.5rem; font-size: 0.65rem; }
        .vf-btn:hover {
            background: var(--white);
            color: var(--black);
        }

        /* ─── PHILOSOPHY ─────────────────────────────────────── */
        .vf-philosophy {
            padding: 15rem 6vw;
            background: var(--black);
        }
        [data-device="mobile"] .vf-philosophy { padding: 6rem 1.75rem; }

        .vf-phil-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10vw;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
        }
        [data-device="mobile"] .vf-phil-grid { grid-template-columns: 1fr; gap: 4rem; text-align: center; }

        .vf-phil-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(3rem, 5vw, 5rem);
            line-height: 1;
            margin-bottom: 3rem;
        }
        [data-device="mobile"] .vf-phil-title { font-size: 2.8rem; line-height: 0.9; margin-bottom: 2rem; }

        .vf-phil-title em {
            color: var(--accent);
            font-style: italic;
        }
        .vf-phil-body {
            font-size: 1.4rem;
            line-height: 1.6;
            color: #888;
            max-width: 35ch;
        }
        [data-device="mobile"] .vf-phil-body { font-size: 1rem; margin: 0 auto; line-height: 1.7; }

        .vf-reveal-wrapper {
            position: relative;
            aspect-ratio: 4/5;
            overflow: hidden;
            background: var(--gray);
            clip-path: inset(0 0 0 0);
        }
        .vf-reveal-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* ─── HORIZONTAL SCROLL ──────────────────────────────── */
        .vf-horizontal-wrap {
            height: 100vh;
            overflow: hidden;
            background: #050505;
        }
        [data-device="mobile"] .vf-horizontal-wrap { height: auto; overflow: visible; background: var(--black); }

        .vf-horizontal-scroll {
            height: 100%;
        }
        .vf-horizontal-inner {
            display: flex;
            height: 100%;
            width: max-content;
            align-items: center;
        }
        [data-device="mobile"] .vf-horizontal-inner {
            flex-direction: column;
            width: 100%;
            height: auto;
        }

        .vf-slide {
            height: 100%;
            width: 80vw;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 0 10vw;
            border-right: 1px solid #111;
        }
        [data-device="mobile"] .vf-slide {
            width: 100%;
            height: auto;
            padding: 6rem 1.75rem;
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .vf-slide--intro {
            width: 60vw;
        }
        .vf-slide-label {
            font-size: 0.8rem;
            color: var(--accent);
            margin-bottom: 2rem;
            font-weight: 700;
        }
        [data-device="mobile"] .vf-slide-label { font-size: 0.65rem; margin-bottom: 1rem; }

        .vf-slide-title {
            font-family: 'Syne', sans-serif;
            font-size: 12vw;
            text-transform: uppercase;
            font-weight: 800;
            line-height: 1;
        }
        [data-device="mobile"] .vf-slide-title { font-size: 4.5rem; line-height: 0.85; }

        .vf-product-card {
            width: 100%;
            max-width: 600px;
            text-align: left;
        }
        [data-device="mobile"] .vf-product-card { text-align: center; }

        .vf-product-img {
            width: 100%;
            aspect-ratio: 1;
            object-fit: cover;
            margin-bottom: 2rem;
            filter: grayscale(1);
            transition: filter 0.8s, transform 0.8s cubic-bezier(0.2, 0, 0.2, 1);
        }
        .vf-product-card:hover .vf-product-img {
            filter: grayscale(0);
            transform: scale(1.02);
        }
        [data-device="mobile"] .vf-product-img { filter: grayscale(0); transform: none !important; }

        .vf-product-info h3 {
            font-family: 'Syne', sans-serif;
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            font-weight: 700;
        }
        [data-device="mobile"] .vf-product-info h3 { font-size: 2rem; margin-bottom: 0.25rem; }

        .vf-product-info p {
            color: var(--muted);
            font-size: 1.1rem;
        }
        [data-device="mobile"] .vf-product-info p { font-size: 0.9rem; }

        .vf-info-block {
            max-width: 35ch;
        }
        [data-device="mobile"] .vf-info-block { margin: 0 auto; text-align: center; }

        .vf-info-label {
            font-size: 0.8rem;
            color: var(--accent);
            margin-bottom: 2rem;
            text-transform: uppercase;
            font-weight: 700;
        }
        .vf-info-block p {
            font-size: 2rem;
            line-height: 1.3;
            font-family: 'Syne', sans-serif;
            font-weight: 500;
        }
        [data-device="mobile"] .vf-info-block p { font-size: 1.6rem; line-height: 1.2; }

        /* ─── CTA SECTION ───────────────────────────────────── */
        .vf-cta-section {
            padding: 20rem 6vw;
            text-align: center;
            border-top: 1px solid #111;
            background: var(--black);
        }
        [data-device="mobile"] .vf-cta-section { padding: 8rem 1.75rem; }

        .vf-cta-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(3rem, 10vw, 12rem);
            margin-bottom: 8rem;
            font-weight: 800;
            line-height: 1;
        }
        [data-device="mobile"] .vf-cta-title { font-size: 3.2rem; margin-bottom: 4rem; line-height: 0.9; }

        .vf-form {
            display: flex;
            max-width: 800px;
            margin: 0 auto;
            gap: 2rem;
            align-items: flex-end;
        }
        [data-device="mobile"] .vf-form { flex-direction: column; align-items: center; gap: 3rem; }

        .vf-input {
            flex: 1;
            background: transparent;
            border: none;
            border-bottom: 2px solid #222;
            padding: 1.5rem 0;
            color: var(--white);
            font-size: 1.5rem;
            outline: none;
            transition: border-color 0.4s;
            font-family: 'Syne', sans-serif;
        }
        [data-device="mobile"] .vf-input { font-size: 1.2rem; width: 100%; text-align: center; padding: 1rem 0; }

        .vf-input:focus {
            border-color: var(--accent);
        }
        .vf-submit {
            background: transparent;
            border: none;
            color: var(--white);
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            letter-spacing: 0.2em;
            font-size: 1.2rem;
            padding-bottom: 1.5rem;
            transition: color 0.3s;
        }
        [data-device="mobile"] .vf-submit { font-size: 1rem; padding-bottom: 0; }
        .vf-submit:hover {
            color: var(--accent);
        }
    </style>
</BaseLayout>
