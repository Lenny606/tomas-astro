---
import { getLangFromUrl, useTranslations } from "../utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const socialLinks = [
  { name: "GITHUB", url: "https://github.com/Lenny606" },
  { name: "INSTAGRAM", url: "#" },
  { name: "FACEBOOK", url: "#" },
  { name: "LINKEDIN", url: "https://www.linkedin.com/in/tomaskravcik/" },
];
---

<footer class="bg-[#050505] text-alabaster py-32 px-12 border-t border-alabaster/5 relative overflow-hidden">
  <!-- Subtle Gradient Glow -->
  <div class="absolute bottom-[-150px] left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-alabaster/[0.03] blur-[120px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-16 mb-24">
      <div class="max-w-sm">
        <h3 class="text-4xl font-serif mb-8 italic tracking-tighter">NebulaLab</h3>
        <p class="text-zinc-500 font-light leading-relaxed text-lg">
          {lang === 'cz' 
            ? 'Vytváření digitálních zážitků, které překlenují propast mezi představivostí a realitou.'
            : 'Creating digital experiences that bridge the gap between imagination and reality.'}
        </p>
      </div>
      
      <div class="flex flex-wrap gap-x-12 gap-y-8">
        {
          socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 text-[11px] font-bold tracking-[0.3em] uppercase transition-colors hover:text-white"
            >
              <span class="w-12 h-[1px] bg-zinc-800 group-hover:w-20 group-hover:bg-alabaster transition-all duration-500"></span>
              {link.name}
            </a>
          ))
        }
      </div>
    </div>

    <div class="pt-12 border-t border-alabaster/10 flex flex-col md:flex-row justify-between items-center gap-8">
      <p class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 font-bold whitespace-nowrap">
        © {new Date().getFullYear()} NEBULALAB • MADE IN PRAGUE
      </p>
      
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-4">
         <a href="#" class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 hover:text-alabaster transition-colors font-bold">Privacy</a>
         <a href="#" class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 hover:text-alabaster transition-colors font-bold">Terms</a>
         <a href="mailto:hello@nebulalab.com" class="text-[10px] uppercase tracking-[0.2em] text-zinc-600 hover:text-alabaster transition-colors font-bold">Contact</a>
      </div>
    </div>
  </div>
</footer>
