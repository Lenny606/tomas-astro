---
import { Image } from "astro:assets";
import { getImageAsset } from "../utils/image-loader";

interface Props {
    title: string;
    description?: string;
    image?: string;
    href: string;
    subtitle?: string;
}

const { title, description, image, href, subtitle } = Astro.props;

const isLink = !!href;
const Tag = isLink ? "a" : "div";

// Resolve the image asset for Astro's Image component
const resolvedImage = image ? await getImageAsset(image) : null;
---

<Tag
    href={isLink ? href : undefined}
    class:list={[
        "group block relative overflow-hidden bg-zinc-900 border border-white/5 transition-[all] duration-500",
        isLink ? "hover:border-white/20 cursor-pointer" : "cursor-default"
    ]}
>
    <div class="aspect-[4/5] overflow-hidden">
        {
            resolvedImage ? (
                <Image
                    src={resolvedImage}
                    alt={title}
                    width={800}
                    height={1000}
                    class:list={[
                        "w-full h-full object-cover transition-[filter,transform] duration-700 ease-out",
                        isLink ? "grayscale group-hover:grayscale-0 group-hover:scale-105" : "grayscale-0 scale-100"
                    ]}
                />
            ) : image ? (
                <img
                    src={image}
                    alt={title}
                    width={800}
                    height={1000}
                    class:list={[
                        "w-full h-full object-cover transition-[filter,transform] duration-700 ease-out",
                        isLink ? "grayscale group-hover:grayscale-0 group-hover:scale-105" : "grayscale-0 scale-100"
                    ]}
                />
            ) : (
                <div class:list={[
                    "w-full h-full bg-linear-to-br from-zinc-800 to-zinc-900 transition-transform duration-700 ease-out",
                    isLink ? "group-hover:scale-105" : ""
                ]} />
            )
        }
    </div>

    <div
        class:list={[
            "absolute inset-0 bg-linear-to-t from-black/90 via-black/20 to-transparent transition-opacity duration-500 flex flex-col justify-end p-8",
            isLink ? "opacity-60 group-hover:opacity-100" : "opacity-80"
        ]}
    >
        <div
            class:list={[
                "transition-transform duration-500",
                isLink ? "translate-y-4 group-hover:translate-y-0" : "translate-y-0"
            ]}
        >
            {
                subtitle && (
                    <p class="text-[10px] uppercase tracking-[0.3em] text-zinc-400 mb-2 font-bold">
                        {subtitle}
                    </p>
                )
            }
            <h3 class="text-2xl font-serif text-alabaster">{title}</h3>
            {
                description && (
                    <p class="text-sm text-zinc-400 mt-2 line-clamp-2 font-light leading-relaxed">
                        {description}
                    </p>
                )
            }
            {isLink && (
                <div
                    class="mt-6 h-[1px] w-0 group-hover:w-full bg-alabaster transition-[width] duration-700 delay-100"
                >
                </div>
            )}
        </div>
    </div>
</Tag>
